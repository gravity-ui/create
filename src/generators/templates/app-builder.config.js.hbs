{{#if hasFrontend}}
const port = process.env.APP_PORT ? Number(process.env.APP_PORT) : 3030;
{{/if}}

export default () => {
    return {
        client: {
{{#if hasReact}}            newJsxTransform: true,{{/if}}
{{#if hasFrontend}}
            devServer: {
                port: port + 1,
            },
{{/if}}
        },
        {{#if hasBackend}}
        server: {
            {{#if hasFrontend}}
            port,
            {{/if}}
        },
        {{/if}}
    };
};
