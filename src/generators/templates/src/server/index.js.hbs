{{#if hasFrontend}}
import path from 'node:path';

import {createLayoutPlugin, createRenderFunction} from '@gravity-ui/app-layout';
{{/if}}
import {ExpressKit} from '@gravity-ui/expresskit';
import {NodeKit} from '@gravity-ui/nodekit';
{{#if hasFrontend}}import express from 'express';{{/if}}

const nodekit = new NodeKit({});
{{#if hasFrontend}}

const renderLayout = createRenderFunction([
    createLayoutPlugin({
        manifest: 'dist/public/build/assets-manifest.json',
        publicPath: '/build/',
    }),
]);
{{/if}}

const app = new ExpressKit(nodekit, {
{{#if hasFrontend}}
    'GET /': (_, res) => {
        res.send(
            renderLayout({
                title: '{{projectName}}',
                pluginsOptions: {layout: {name: '{{entryFileName}}'}},
            }),
        );
    },
{{else}}
    'GET /': (_, res) => {
        res.send('Hello, world!');
    },
{{/if}}
});
{{#if hasFrontend}}
app.express.use(express.static(path.join('dist', 'public')));
{{/if}}

app.run();
