    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./lib",
    "resolveJsonModule": true,
    "checkJs": true,
    "types": ["node"]
  },
  "include": ["src/**/*", "scripts/**/*", "e2e/**/*", "playwright.config.ts"]
}
